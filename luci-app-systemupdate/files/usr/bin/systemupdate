#!/bin/sh

REPO="zjt37/zheng"
API_URL="https://api.github.com/repos/${REPO}/releases/latest"
DOWNLOAD_DIR="/tmp/firmware"
OVERLAY_BACKUP="/tmp/overlay_backup"

get_release_info() {
    RELEASE_JSON=$(curl -s "${API_URL}")
    
    if [ -z "$RELEASE_JSON" ]; then
        echo "错误: 无法获取更新信息"
        return 1
    fi
    
    TAG_NAME=$(echo "$RELEASE_JSON" | jq -r '.tag_name')
    ASSET_URL=$(echo "$RELEASE_JSON" | jq -r '.assets[] | select(.name == "openwrt.img") | .browser_download_url')
    FILE_SIZE=$(echo "$RELEASE_JSON" | jq -r '.assets[] | select(.name == "openwrt.img") | .size')
    
    if [ -z "$ASSET_URL" ] || [ "$ASSET_URL" = "null" ]; then
        echo "错误: 未找到固件文件"
        return 1
    fi
    
    return 0
}

get_root_dev() {
    MOUNT_SRC=$(mount | grep ' / ' | awk '{print $1}')
    
    if echo "$MOUNT_SRC" | grep -q "overlayfs"; then
        ROOT_UUID=$(cat /proc/cmdline | tr ' ' '\n' | grep '^root=' | cut -d= -f2- | sed 's/PARTUUID=//;s/-[0-9]*$//')
        for dev in /dev/sd? /dev/vd? /dev/nvme?n?; do
            if [ -b "$dev" ] && blkid "$dev" 2>/dev/null | grep -qi "$ROOT_UUID"; then
                echo "$dev"
                return 0
            fi
        done
        echo "/dev/sda"
    else
        echo "$MOUNT_SRC" | sed 's/[0-9]*$//'
    fi
}

check_update() {
    echo "=== 检查更新 ==="
    echo "仓库: ${REPO}"
    echo ""
    
    get_release_info
    if [ $? -ne 0 ]; then return 1; fi
    
    FILE_SIZE_MB=$((FILE_SIZE / 1024 / 1024))
    
    echo "最新版本: ${TAG_NAME}"
    echo "固件大小: ${FILE_SIZE_MB} MB"
    echo "下载地址: ${ASSET_URL}"
    echo ""
    echo "固件信息获取成功，可以开始更新"
}

download_firmware() {
    mkdir -p "${DOWNLOAD_DIR}"
    
    echo "正在下载固件..."
    rm -f "${DOWNLOAD_DIR}/openwrt.img"
    curl -s -L -o "${DOWNLOAD_DIR}/openwrt.img" "${ASSET_URL}" &
    CURL_PID=$!
    
    while kill -0 $CURL_PID 2>/dev/null; do
        sleep 5
        if [ -f "${DOWNLOAD_DIR}/openwrt.img" ]; then
            CURRENT=$(ls -l "${DOWNLOAD_DIR}/openwrt.img" 2>/dev/null | awk '{print $5}')
            CURRENT=${CURRENT:-0}
            if [ "$FILE_SIZE" -gt 0 ] 2>/dev/null; then
                PERCENT=$((CURRENT * 100 / FILE_SIZE))
                CURRENT_MB=$((CURRENT / 1024 / 1024))
                TOTAL_MB=$((FILE_SIZE / 1024 / 1024))
                echo "下载进度: ${PERCENT}% (${CURRENT_MB}/${TOTAL_MB} MB)"
            fi
        fi
    done
    wait $CURL_PID
    
    if [ $? -ne 0 ]; then
        echo "错误: 下载失败"
        return 1
    fi
    
    echo "下载完成，校验文件..."
    DOWNLOADED_SIZE=$(stat -c%s "${DOWNLOAD_DIR}/openwrt.img" 2>/dev/null || stat -f%z "${DOWNLOAD_DIR}/openwrt.img" 2>/dev/null)
    
    if [ "$DOWNLOADED_SIZE" -ne "$FILE_SIZE" ]; then
        echo "错误: 文件大小不匹配 (期望: ${FILE_SIZE}, 实际: ${DOWNLOADED_SIZE})"
        return 1
    fi
    
    echo "文件校验通过"
    return 0
}

backup_overlay() {
    echo "=== 备份配置 ==="
    echo "正在备份 /overlay..."
    
    rm -rf "${OVERLAY_BACKUP}"
    mkdir -p "${OVERLAY_BACKUP}"
    
    if [ -d "/overlay" ]; then
        tar -czf "${OVERLAY_BACKUP}/overlay_backup.tar.gz" -C / overlay 2>/dev/null
        if [ $? -eq 0 ]; then
            echo "配置备份完成"
            return 0
        else
            echo "警告: 备份可能不完整"
            return 0
        fi
    else
        echo "警告: 未找到 /overlay 目录"
        return 0
    fi
}

fresh_install() {
    echo "=== 全新安装 ==="
    
    get_release_info
    if [ $? -ne 0 ]; then return 1; fi
    
    download_firmware
    if [ $? -ne 0 ]; then return 1; fi
    
    ROOT_DEV=$(get_root_dev)
    
    if [ -z "$ROOT_DEV" ] || [ ! -b "$ROOT_DEV" ]; then
        echo "错误: 无法确定根设备"
        return 1
    fi
    
    echo "当前根设备: ${ROOT_DEV}"
    echo "正在刷入固件（全新安装），请勿断电..."
    
    dd if="${DOWNLOAD_DIR}/openwrt.img" of="${ROOT_DEV}" bs=4M conv=fsync 2>&1
    
    if [ $? -eq 0 ]; then
        echo "刷入完成！"
        echo "系统将在 10 秒后重启..."
        sleep 10
        reboot
    else
        echo "错误: 刷入失败"
        return 1
    fi
}

keep_settings() {
    echo "=== 保留配置更新 ==="
    
    backup_overlay
    
    get_release_info
    if [ $? -ne 0 ]; then return 1; fi
    
    download_firmware
    if [ $? -ne 0 ]; then return 1; fi
    
    ROOT_DEV=$(get_root_dev)
    
    if [ -z "$ROOT_DEV" ] || [ ! -b "$ROOT_DEV" ]; then
        echo "错误: 无法确定根设备"
        return 1
    fi
    
    echo "当前根设备: ${ROOT_DEV}"
    echo "正在刷入固件（保留配置），请勿断电..."
    
    dd if="${DOWNLOAD_DIR}/openwrt.img" of="${ROOT_DEV}" bs=4M conv=fsync 2>&1
    
    if [ $? -eq 0 ]; then
        echo "刷入完成！"
        echo "正在设置配置恢复..."
        
        mkdir -p /overlay/etc/uci-defaults
        cat > /overlay/etc/uci-defaults/99-restore-overlay <<'EOF'
#!/bin/sh
if [ -f /tmp/overlay_backup/overlay_backup.tar.gz ]; then
    tar -xzf /tmp/overlay_backup/overlay_backup.tar.gz -C / 2>/dev/null
    rm -rf /tmp/overlay_backup
    reboot
fi
EOF
        chmod +x /overlay/etc/uci-defaults/99-restore-overlay
        
        echo "系统将在 10 秒后重启..."
        sleep 10
        reboot
    else
        echo "错误: 刷入失败"
        return 1
    fi
}

case "$1" in
    check)
        check_update
        ;;
    fresh)
        fresh_install
        ;;
    keep)
        keep_settings
        ;;
    *)
        echo "用法: $0 {check|fresh|keep}"
        echo "  check  - 检查更新"
        echo "  fresh  - 全新安装（不保留配置）"
        echo "  keep   - 保留配置更新"
        ;;
esac
